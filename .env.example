# Claude API (obligatorio para respuestas inteligentes)
ANTHROPIC_API_KEY=sk-ant...

# Admin token para /admin/* (cambiar en producción)
ADMIN_TOKEN=December2nd!

# Enviar mensajes reales por WhatsApp.
#   false -> solo logs (dry-run, recomendado al empezar)
#   true  -> manda de verdad por el whatsapp-bridge
SEND_ENABLED=false

# Nombre visible del bot (se usa para triggers en grupos)
BOT_NAME=Ammos

# Zona horaria por defecto para programación de templates
TIMEZONE=America/Argentina/Cordoba

# Rate limit del sender y frecuencia del worker
MAX_MSG_PER_SEC=1
SCHEDULER_INTERVAL_SEC=30
